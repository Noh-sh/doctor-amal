# URL проекта Supabase для проекта Doctor Amal.
# Где взять: Supabase Dashboard -> Project Settings -> API Keys или Data API -> Project URL.
DOCTOR_SUPABASE_URL=

# Publishable key для чтения опубликованного контента страницы.
# Используется только вместе с RLS policies и не должен давать права записи.
DOCTOR_SUPABASE_PUBLISHABLE_KEY=

# Legacy-вариант, если Supabase project показывает anon key вместо publishable key.
# Обычно не нужен, если заполнен DOCTOR_SUPABASE_PUBLISHABLE_KEY.
DOCTOR_SUPABASE_ANON_KEY=

# Server-only service role key.
# На текущем этапе код проекта его НЕ использует.
# Нельзя добавлять в NEXT_PUBLIC_*.
# Нельзя отправлять в чат или коммитить в git.
# Заполнять только для отдельной server-only задачи после отдельного specs/плана.
DOCTOR_SUPABASE_SERVICE_ROLE_KEY=
