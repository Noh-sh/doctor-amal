# Реальные значения хранить только в `.env.local`.

# Public Supabase env.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Server-side/project env.
# Обычно такое же значение, как у `NEXT_PUBLIC_SUPABASE_URL`.
DOCTOR_SUPABASE_URL=

# Server-only secret. Не добавлять в `NEXT_PUBLIC_*`.
# Текущий код его не использует.
DOCTOR_SUPABASE_SERVICE_ROLE_KEY=
